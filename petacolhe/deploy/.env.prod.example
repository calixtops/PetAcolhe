# Variáveis de produção para PetAcolhe no servidor
# Copie para .env.prod e ajuste os secrets

POSTGRES_DB=petacolhe
POSTGRES_USER=petacolhe
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# Gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_POR_HEX_LONGO_AQUI

# URL pública (usada para gerar links de /uploads). Ajuste quando tiver domínio.
PETACOLHE_PUBLIC_URL=http://SEU_IP_OU_DOMINIO
